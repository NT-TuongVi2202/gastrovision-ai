APP_ENV=local
MAX_UPLOAD_SIZE_MB=5
CONFIDENCE_THRESHOLD=0.60
INFERENCE_TIMEOUT_SECONDS=30

# Classifier = SVM on ResNet50 ImageNet features.
# If unset, backend looks under backend/models/svm_classifier/.
CLASSIFIER_MODEL_DIR=models/svm_classifier
SVM_MODEL_PATH=models/svm_classifier/svm_model.pkl
SVM_SCALER_PATH=models/svm_classifier/scaler.pkl
CLASSIFIER_LABELS_PATH=models/svm_classifier/labels.json
FEATURE_BACKBONE_WEIGHTS=DEFAULT
