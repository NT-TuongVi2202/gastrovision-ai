APP_ENV=local
MAX_UPLOAD_SIZE_MB=5
CONFIDENCE_THRESHOLD=0.60
INFERENCE_TIMEOUT_SECONDS=30

# Classifier = SVM on ResNet50 ImageNet features.
# Paths are absolute (artifacts/ lives at repo root, not inside backend/).
# main.py reads these via Path(os.getenv(...)); absolute paths avoid cwd-relative bugs.
CLASSIFIER_MODEL_DIR=D:/đồ án_archive/gastrovision-ai/artifacts/models/svm_classifier
SVM_MODEL_PATH=D:/đồ án_archive/gastrovision-ai/artifacts/models/svm_classifier/svm_model.pkl
SVM_SCALER_PATH=D:/đồ án_archive/gastrovision-ai/artifacts/models/svm_classifier/scaler.pkl
CLASSIFIER_LABELS_PATH=D:/đồ án_archive/gastrovision-ai/artifacts/models/svm_classifier/labels.json
FEATURE_BACKBONE_WEIGHTS=DEFAULT
