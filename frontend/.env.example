# Frontend env (Vite). Copy to .env and adjust if needed.
# Backend FastAPI endpoint (default local).
VITE_API_BASE_URL=http://localhost:8080
# Use built-in mock API instead of real backend (useful for UI demo without models).
VITE_USE_MOCK_API=false
# Max upload size in MB (frontend validation).
VITE_MAX_UPLOAD_SIZE_MB=5